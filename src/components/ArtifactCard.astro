---
import type { CollectionEntry } from 'astro:content';

interface Props {
  artifact: CollectionEntry<'artifacts'>;
}

const { artifact } = Astro.props;
const { name, type, area, description, authors, paper, status, tags, badges, logo } = artifact.data;
const logoSrc = logo ? (/^https?:\/\//i.test(logo) ? logo : `/logos/${logo}.svg`) : null;
const search = [
  name,
  description,
  type,
  area,
  status,
  ...authors,
  ...tags,
  ...badges,
  paper?.title ?? '',
  paper?.venue ?? '',
  paper?.year?.toString() ?? '',
]
  .join(' ')
  .normalize('NFD')
  .replace(/[\u0300-\u036f]/g, '')
  .toLowerCase();
---

<a
  class="card"
  href={`/artifacts/${artifact.id}/`}
  data-type={type}
  data-area={area}
  data-search={search}
  data-tags={JSON.stringify(tags)}
>
  <span class="card-area">{area}</span>
  <div class="card-head">
    <h3>{name}</h3>
    <span class={`badge ${type}`}>{type}</span>
  </div>
  <p>{description}</p>
  <div class="card-meta">
    {paper && <span class="venue-badge">{paper.venue} {paper.year}</span>}
    <span class={`status ${status}`}>{status}</span>
  </div>
  {logoSrc && <img class="card-logo" src={logoSrc} width="22" height="22" alt="" loading="lazy" />}
</a>
