---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Research artifacts from the TruX group at SnT, University of Luxembourg' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a href="/" class="brand" aria-label="TruX Artifacts home">
          <span class="logo">
            <span class="logo-text">TruX</span>
            <span class="logo-bars" aria-hidden="true"><i></i><i></i><i></i><i></i></span>
          </span>
          <span class="brand-sub">Artifacts</span>
        </a>
        <nav>
          <a href="https://www.uni.lu/snt-en/research-groups/trux/" target="_blank" rel="noopener noreferrer">TruX group</a>
          <a href="https://github.com/Trustworthy-Software" target="_blank" rel="noopener noreferrer">GitHub</a>
        </nav>
        <a href="https://www.uni.lu/snt-en/" target="_blank" rel="noopener noreferrer" class="header-logo-link">
          <img class="header-logo" src="/snt-uni-logo.svg" alt="SnT — Interdisciplinary Centre for Security, Reliability and Trust, University of Luxembourg" />
        </a>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container">
        <span>Trustworthy Software Engineering (TruX) — SnT, University of Luxembourg</span>
      </div>
    </footer>
  </body>
</html>
