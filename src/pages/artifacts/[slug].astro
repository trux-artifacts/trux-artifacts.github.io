---
import { getCollection, type CollectionEntry } from 'astro:content';
import fs from 'node:fs';
import path from 'node:path';
import Base from '../../layouts/Base.astro';
import people from '../../data/people.json';

export async function getStaticPaths() {
  const artifacts = await getCollection('artifacts');
  return artifacts.map((artifact) => ({
    params: { slug: artifact.id },
    props: { artifact },
  }));
}

interface Props {
  artifact: CollectionEntry<'artifacts'>;
}

const { artifact }: Props = Astro.props;
const { name, type, description, authors, addedAt, paper, links, badges, tags, license, bibtex, figure, figureCaption, demo, dataset } =
  artifact.data;
const addedDate = new Intl.DateTimeFormat('en-GB', {
  day: 'numeric',
  month: 'short',
  year: 'numeric',
  timeZone: 'UTC',
}).format(new Date(`${addedAt}T00:00:00Z`));

// Load a large sample pool from an external file at build time, so big datasets
// (e.g. thousands of hashes) stay out of the YAML.
let datasetData = dataset;
if (dataset?.samplesFile) {
  const samplesRoot = path.resolve(process.cwd(), 'src/data/samples');
  const samplePath = path.resolve(samplesRoot, dataset.samplesFile);
  const relativePath = path.relative(samplesRoot, samplePath);
  const isInsideSamples =
    relativePath !== '' &&
    relativePath !== '..' &&
    !relativePath.startsWith(`..${path.sep}`) &&
    !path.isAbsolute(relativePath);

  if (!isInsideSamples) {
    throw new Error(
      `[artifact:${artifact.id}] Invalid samplesFile "${dataset.samplesFile}": it must resolve inside ${samplesRoot}`
    );
  }
  if (!fs.existsSync(samplePath)) {
    throw new Error(
      `[artifact:${artifact.id}] samplesFile "${dataset.samplesFile}" does not exist at ${samplePath}`
    );
  }
  const sampleStat = fs.statSync(samplePath);
  if (!sampleStat.isFile()) {
    throw new Error(
      `[artifact:${artifact.id}] samplesFile "${dataset.samplesFile}" is not a regular file: ${samplePath}`
    );
  }
  if (sampleStat.size > 5_000_000) {
    throw new Error(
      `[artifact:${artifact.id}] samplesFile "${dataset.samplesFile}" exceeds the 5 MB build limit`
    );
  }

  // Resolve symlinks as a second containment check before reading the file.
  const realSamplesRoot = fs.realpathSync(samplesRoot);
  const realSamplePath = fs.realpathSync(samplePath);
  const realRelativePath = path.relative(realSamplesRoot, realSamplePath);
  if (
    realRelativePath === '' ||
    realRelativePath === '..' ||
    realRelativePath.startsWith(`..${path.sep}`) ||
    path.isAbsolute(realRelativePath)
  ) {
    throw new Error(
      `[artifact:${artifact.id}] samplesFile "${dataset.samplesFile}" resolves outside ${realSamplesRoot}`
    );
  }

  const rows = fs.readFileSync(realSamplePath, 'utf-8').split('\n').map((s) => s.trim()).filter(Boolean);
  if (rows.length > 10_000) {
    throw new Error(
      `[artifact:${artifact.id}] samplesFile "${dataset.samplesFile}" exceeds the 10,000-row limit`
    );
  }
  datasetData = { ...dataset, samples: rows };
}

function safeHttpUrl(value?: string): string | undefined {
  if (!value) return undefined;
  try {
    const url = new URL(value);
    if (
      (url.protocol === 'http:' || url.protocol === 'https:') &&
      url.username === '' &&
      url.password === ''
    ) {
      return url.href;
    }
  } catch {
    // Invalid and non-HTTP(S) URLs are deliberately not rendered.
  }
  return undefined;
}

const site = (authorName: string): string | undefined =>
  safeHttpUrl((people as Record<string, string>)[authorName]);

const safeLinks = {
  github: safeHttpUrl(links.github),
  website: safeHttpUrl(links.website),
  download: safeHttpUrl(links.download),
  access: safeHttpUrl(links.access),
  video: safeHttpUrl(links.video),
  resources: (links.resources ?? []).flatMap((resource) => {
    const url = safeHttpUrl(resource.url);
    return url ? [{ ...resource, url }] : [];
  }),
};

const figureSrc = figure
  ? safeHttpUrl(figure) ??
    (figure.startsWith('/')
      ? figure
      : `/figures/${figure.split('/').map(encodeURIComponent).join('/')}`)
  : null;

function toEmbed(url: string): string | null {
  try {
    const parsed = new URL(url);
    if (parsed.protocol !== 'http:' && parsed.protocol !== 'https:') return null;
    const host = parsed.hostname.toLowerCase().replace(/^www\./, '');
    let videoId: string | null = null;

    if (host === 'youtu.be') {
      videoId = parsed.pathname.split('/').filter(Boolean)[0] ?? null;
    } else if (
      host === 'youtube.com' ||
      host === 'm.youtube.com' ||
      host === 'youtube-nocookie.com'
    ) {
      const parts = parsed.pathname.split('/').filter(Boolean);
      if (parsed.pathname === '/watch') videoId = parsed.searchParams.get('v');
      else if (parts[0] === 'embed' || parts[0] === 'shorts') videoId = parts[1] ?? null;
    }

    return videoId && /^[A-Za-z0-9_-]{11}$/.test(videoId)
      ? `https://www.youtube-nocookie.com/embed/${videoId}`
      : null;
  } catch {
    return null;
  }
}
const embed = safeLinks.video ? toEmbed(safeLinks.video) : null;
const doiHref = paper?.doi
  ? `https://doi.org/${paper.doi.split('/').map(encodeURIComponent).join('/')}`
  : null;
const paperUrl = safeHttpUrl(paper?.url);
const statNumberFormat = new Intl.NumberFormat('en-US', { maximumFractionDigits: 20 });
---

<Base title={`${name} — TruX Artifacts`} description={description}>
  <div class="container">
  <div class="detail">
    <a class="back-link" href="/">← All artifacts</a>
    <div class="type-row">
      <span class={`badge ${type}`}>{type}</span>
      {badges.map((b) => <span class="award">{b}</span>)}
      <time class="artifact-added" datetime={addedAt}>Added to the catalog {addedDate}</time>
    </div>
    <h1>{name}</h1>
    <p class="lead">{description}</p>
    <p class="authors">
      {authors.map((a, i) => (
        <>
          {site(a) ? (
            <a href={site(a)} target="_blank" rel="noopener noreferrer">{a}</a>
          ) : (
            a
          )}
          {i < authors.length - 1 && ', '}
        </>
      ))}
      {license && ` · ${license} license`}
    </p>

    {tags.length > 0 && (
      <div class="tag-row top-tags">
        {tags.map((t) => (
          <a class="tag" href={`/?topic=${encodeURIComponent(t)}`} title={`See all artifacts about ${t}`}>{t}</a>
        ))}
      </div>
    )}

    <div class="btn-row">
      {safeLinks.github && <a class="btn primary" href={safeLinks.github} target="_blank" rel="noopener noreferrer">View on GitHub</a>}
      {safeLinks.website && <a class="btn" href={safeLinks.website} target="_blank" rel="noopener noreferrer">Website</a>}
      {safeLinks.download && <a class="btn" href={safeLinks.download} target="_blank" rel="noopener noreferrer">Download</a>}
      {safeLinks.access && <a class="btn" href={safeLinks.access} target="_blank" rel="noopener noreferrer">Request access</a>}
      {safeLinks.video && !embed && <a class="btn" href={safeLinks.video} target="_blank" rel="noopener noreferrer">Watch demo</a>}
      {safeLinks.resources.map((r) => (
        <a class="btn" href={r.url} target="_blank" rel="noopener noreferrer">{r.label}</a>
      ))}
      {bibtex && <button class="btn" id="copy-bibtex" type="button" aria-controls="bibtex">Copy BibTeX</button>}
    </div>

    {embed && (
      <div class="section">
        <h2>Demonstration</h2>
        <div class="video-wrap">
          <iframe
            src={embed}
            title={`${name} demonstration video`}
            loading="lazy"
            referrerpolicy="strict-origin-when-cross-origin"
            sandbox="allow-scripts allow-same-origin allow-presentation"
            allow="accelerometer; autoplay; encrypted-media; gyroscope; picture-in-picture; web-share"
            allowfullscreen
          />
        </div>
      </div>
    )}

    {figureSrc && (
      <div class="section">
        <h2>How it works</h2>
        <figure class="figure-box">
          <img
            src={figureSrc}
            alt={figureCaption ?? `Overview of the ${name} approach`}
            loading="lazy"
            decoding="async"
            referrerpolicy="no-referrer"
          />
          {figureCaption && <figcaption>{figureCaption}</figcaption>}
        </figure>
      </div>
    )}

    {demo && (
      <div class="section">
        <h2>Interactive demo</h2>
        {demo.intro && <p class="demo-intro">{demo.intro}</p>}
        <div class="demo-box" id="demo" data-demo={JSON.stringify(demo)}>
          <div class="demo-tasks">
            {demo.scenarios.map((s, i) => (
              <button
                class="btn demo-task"
                type="button"
                data-i={i}
                aria-pressed="false"
                aria-controls="demo-stage"
              >{s.label}</button>
            ))}
          </div>
          <div
            class="demo-stage"
            id="demo-stage"
            role="region"
            aria-label="Interactive demo output"
            aria-live="polite"
            aria-atomic="false"
            aria-busy="false"
            tabindex="-1"
          >
            <p class="demo-hint">Pick a task above to see it in action.</p>
          </div>
        </div>
        <p class="demo-note">{demo.note}</p>
      </div>
    )}

    {datasetData && (
      <div class="section">
        <h2>Explore the dataset</h2>
        <div class="ds-stats">
          {datasetData.stats.map((s) => (
            <div class="ds-stat">
              <span class="ds-stat-num" data-target={s.value} data-suffix={s.suffix} data-animate={String(s.animate)}>{`${statNumberFormat.format(s.value)}${s.suffix}`}</span>
              <span class="ds-stat-label">{s.label}</span>
            </div>
          ))}
        </div>
        {datasetData.samples?.length > 0 && (
          <div class="ds-sample" id="ds-sample" data-dataset={JSON.stringify(datasetData)}>
            <div class="ds-sample-head">
              <span class="ds-sample-title">
                {datasetData.sampleTitle}{datasetData.sampleSource ? ` · ${datasetData.sampleSource}` : ''}
              </span>
              <button class="btn ds-shuffle" id="ds-shuffle" type="button" aria-controls="ds-sample-body">Draw random sample ↻</button>
            </div>
            <div class="ds-sample-body" id="ds-sample-body" aria-live="polite"></div>
          </div>
        )}
        {datasetData.samples?.length > 0 && datasetData.sampleNote && <p class="demo-note">{datasetData.sampleNote}</p>}

        {datasetData.usage && (
          <div class="ds-usage">
            <div class="ds-usage-head">
              <span class="ds-sample-title">{datasetData.usage.title}</span>
              <button class="btn" id="ds-copy-usage" type="button" aria-controls="ds-usage-code">Copy</button>
            </div>
            {datasetData.usage.note && <p class="demo-note ds-usage-note">{datasetData.usage.note}</p>}
            <pre class="ds-usage-code" id="ds-usage-code">{datasetData.usage.code.trim()}</pre>
          </div>
        )}
      </div>
    )}

    {paper && (
      <div class="section">
        <h2>Paper</h2>
        <div class="paper-box">
          {doiHref ? (
            <a href={doiHref} target="_blank" rel="noopener noreferrer">{paper.title}</a>
          ) : paperUrl ? (
            <a href={paperUrl} target="_blank" rel="noopener noreferrer">{paper.title}</a>
          ) : (
            paper.title
          )}
          <div class="venue">{paper.venue} {paper.year}{paper.doi && ` · DOI: ${paper.doi}`}</div>
        </div>
      </div>
    )}

    {bibtex && (
      <div class="section">
        <h2>Cite this artifact</h2>
        <pre class="bibtex" id="bibtex">{bibtex.trim()}</pre>
      </div>
    )}

  </div>
  </div>

  <script>
    const prefersReducedMotion =
      window.matchMedia?.('(prefers-reduced-motion: reduce)')?.matches ?? false;
    const sleep = (ms: number) =>
      prefersReducedMotion ? Promise.resolve() : new Promise((resolve) => setTimeout(resolve, ms));
    const rand = (min: number, max: number) => min + Math.random() * (max - min);

    const btn = document.getElementById('copy-bibtex');
    const bib = document.getElementById('bibtex');
    btn?.addEventListener('click', async () => {
      await navigator.clipboard.writeText(bib?.textContent ?? '');
      btn.textContent = 'Copied';
      setTimeout(() => (btn.textContent = 'Copy BibTeX'), 1500);
    });

    const demoBox = document.getElementById('demo');
    if (demoBox) {
      const demoData = JSON.parse(demoBox.dataset.demo ?? '{}');
      const stage = document.getElementById('demo-stage')!;
      const taskBtns = demoBox.querySelectorAll<HTMLButtonElement>('.demo-task');
      let run = 0;

      const brainSvg =
        '<svg class="demo-brain" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">' +
        '<path d="M9.5 3.5a2.4 2.4 0 0 0-2.4 2.4 2.3 2.3 0 0 0-1.6 2.2 2.3 2.3 0 0 0 .5 1.4 2.5 2.5 0 0 0-.9 1.9 2.5 2.5 0 0 0 1 2 2.4 2.4 0 0 0 1.4 3.6 2.4 2.4 0 0 0 2.5 2 1.3 1.3 0 0 0 1.3-1.3V4.8a1.4 1.4 0 0 0-1.8-1.3z"/>' +
        '<path d="M14.5 3.5a2.4 2.4 0 0 1 2.4 2.4 2.3 2.3 0 0 1 1.6 2.2 2.3 2.3 0 0 1-.5 1.4 2.5 2.5 0 0 1 .9 1.9 2.5 2.5 0 0 1-1 2 2.4 2.4 0 0 1-1.4 3.6 2.4 2.4 0 0 1-2.5 2 1.3 1.3 0 0 1-1.3-1.3V4.8a1.4 1.4 0 0 1 1.8-1.3z"/>' +
        '</svg>';

      async function playLlm(myRun: number, s: any) {
        const query = document.createElement('p');
        query.className = 'demo-query';
        query.textContent = '❯ ' + s.query;
        stage.appendChild(query);

        const think = document.createElement('div');
        think.className = 'demo-thinking';
        think.innerHTML = brainSvg + '<span class="demo-think-msg"></span>';
        stage.appendChild(think);
        const msg = think.querySelector('.demo-think-msg')!;

        for (const t of s.thinking) {
          if (run !== myRun) return;
          msg.textContent = t;
          await sleep(rand(700, 1500));
        }
        if (run !== myRun) return;

        think.remove();
        const head = document.createElement('p');
        head.className = 'demo-output-label';
        const showCount = demoData.countOutput !== false;
        head.textContent = showCount
          ? `${demoData.outputLabel} (${s.output.length})`
          : demoData.outputLabel;
        stage.appendChild(head);

        const list = document.createElement('div');
        list.className = 'demo-output';
        stage.appendChild(list);
        for (const m of s.output) {
          if (run !== myRun) return;
          const line = document.createElement('code');
          line.className = 'demo-method';
          line.textContent = m;
          list.appendChild(line);
          await sleep(rand(50, 190));
        }
      }

      async function playTerminal(myRun: number, s: any) {
        const term = document.createElement('div');
        term.className = 'demo-terminal';
        term.innerHTML =
          '<div class="demo-terminal-bar"><i class="r"></i><i class="y"></i><i class="g"></i></div>';
        const body = document.createElement('div');
        body.className = 'demo-terminal-body';
        term.appendChild(body);
        stage.appendChild(term);

        const prompt = document.createElement('div');
        prompt.innerHTML = '<span class="demo-term-prompt">❯</span> <span class="demo-term-cmd"></span>';
        prompt.querySelector('.demo-term-cmd')!.textContent = s.query;
        body.appendChild(prompt);

        const cursorLine = document.createElement('div');
        cursorLine.innerHTML = '<span class="demo-term-cursor"></span>';
        body.appendChild(cursorLine);

        for (const t of s.thinking) {
          if (run !== myRun) return;
          const line = document.createElement('div');
          line.className = 'demo-term-think';
          line.textContent = t;
          body.insertBefore(line, cursorLine);
          body.scrollTop = body.scrollHeight;
          await sleep(rand(500, 1400));
        }
        if (run !== myRun) return;

        // Long real outputs stream faster so the run stays snappy.
        const [lo, hi] = s.output.length > 30 ? [8, 32] : [50, 220];
        for (const m of s.output) {
          if (run !== myRun) return;
          const line = document.createElement('div');
          line.className = 'demo-term-out';
          line.textContent = m;
          body.insertBefore(line, cursorLine);
          body.scrollTop = body.scrollHeight;
          await sleep(rand(lo, hi));
        }
      }

      async function playPatch(myRun: number, s: any) {
        // Thinking phase: a small brain-free "working" line above the patch.
        const think = document.createElement('div');
        think.className = 'demo-thinking';
        think.innerHTML = brainSvg + '<span class="demo-think-msg"></span>';
        stage.appendChild(think);
        const msg = think.querySelector('.demo-think-msg')!;
        for (const t of s.thinking) {
          if (run !== myRun) return;
          msg.textContent = t;
          await sleep(rand(650, 1400));
        }
        if (run !== myRun) return;
        think.remove();

        // Patch card: header (file + fix pattern), then a colored diff.
        const card = document.createElement('div');
        card.className = 'demo-diff';

        const bar = document.createElement('div');
        bar.className = 'demo-diff-bar';
        const fileEl = document.createElement('span');
        fileEl.className = 'demo-diff-file';
        fileEl.textContent = s.file ?? 'patch.diff';
        bar.appendChild(fileEl);
        if (s.pattern) {
          const pat = document.createElement('span');
          pat.className = 'demo-diff-pattern';
          pat.textContent = s.pattern;
          bar.appendChild(pat);
        }
        card.appendChild(bar);

        const bodyEl = document.createElement('div');
        bodyEl.className = 'demo-diff-body';
        card.appendChild(bodyEl);
        stage.appendChild(card);

        for (const raw of s.output) {
          if (run !== myRun) return;
          const line = document.createElement('div');
          const c = raw.charAt(0);
          const kind =
            raw.startsWith('@@') ? 'hunk'
            : c === '+' ? 'add'
            : c === '-' ? 'del'
            : 'ctx';
          line.className = 'demo-diff-line ' + kind;
          const gutter = document.createElement('span');
          gutter.className = 'demo-diff-gutter';
          gutter.textContent = kind === 'add' ? '+' : kind === 'del' ? '-' : ' ';
          const code = document.createElement('span');
          code.className = 'demo-diff-code';
          code.textContent = kind === 'add' || kind === 'del' ? raw.slice(1) : raw;
          line.appendChild(gutter);
          line.appendChild(code);
          bodyEl.appendChild(line);
          await sleep(rand(60, 150));
        }
      }

      const pixelSvg =
        '<svg class="demo-brain" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">' +
        '<rect x="3" y="3" width="5" height="5" rx="1"/><rect x="10" y="3" width="5" height="5" rx="1" opacity="0.55"/><rect x="17" y="3" width="4" height="5" rx="1"/>' +
        '<rect x="3" y="10" width="5" height="5" rx="1" opacity="0.55"/><rect x="10" y="10" width="5" height="5" rx="1"/><rect x="17" y="10" width="4" height="5" rx="1" opacity="0.55"/>' +
        '<rect x="3" y="17" width="5" height="4" rx="1"/><rect x="10" y="17" width="5" height="4" rx="1" opacity="0.55"/><rect x="17" y="17" width="4" height="4" rx="1"/></svg>';

      function createVerdictIcon(bad: boolean): SVGSVGElement {
        const namespace = 'http://www.w3.org/2000/svg';
        const svg = document.createElementNS(namespace, 'svg');
        svg.setAttribute('viewBox', '0 0 24 24');
        svg.setAttribute('fill', 'none');
        svg.setAttribute('stroke', 'currentColor');
        svg.setAttribute('stroke-width', '2.2');
        svg.setAttribute('stroke-linecap', 'round');
        svg.setAttribute('aria-hidden', 'true');

        const path = document.createElementNS(namespace, 'path');
        if (bad) {
          path.setAttribute('d', 'M18 6 6 18M6 6l12 12');
        } else {
          svg.setAttribute('stroke-linejoin', 'round');
          path.setAttribute('d', 'M20 6 9 17l-5-5');
        }
        svg.appendChild(path);
        return svg;
      }

      function drawDex(canvas: HTMLCanvasElement, seed: number) {
        const N = 128;
        const ctx = canvas.getContext('2d')!;
        const img = ctx.createImageData(N, N);
        let st = seed >>> 0;
        const rnd = () => { st = (st * 1664525 + 1013904223) >>> 0; return st / 4294967296; };
        const bands: { y1: number; base: number; f: number }[] = [];
        let y = 0;
        while (y < N) {
          const h = 5 + Math.floor(rnd() * 20);
          bands.push({ y1: Math.min(N, y + h), base: 25 + rnd() * 175, f: 0.12 + rnd() * 0.85 });
          y += h;
        }
        for (let row = 0; row < N; row++) {
          let band = bands[0];
          for (const b of bands) { if (row < b.y1) { band = b; break; } }
          for (let col = 0; col < N; col++) {
            const streak = Math.sin(col * band.f) * 18;
            let v = band.base + streak + (rnd() - 0.5) * 55;
            v = v < 0 ? 0 : v > 255 ? 255 : v;
            const i = (row * N + col) * 4;
            img.data[i] = img.data[i + 1] = img.data[i + 2] = v;
            img.data[i + 3] = 255;
          }
        }
        ctx.putImageData(img, 0, 0);
      }

      async function playImage(myRun: number, s: any) {
        const think = document.createElement('div');
        think.className = 'demo-thinking';
        think.innerHTML = pixelSvg + '<span class="demo-think-msg"></span>';
        stage.appendChild(think);
        const msg = think.querySelector('.demo-think-msg')!;
        for (const t of s.thinking) {
          if (run !== myRun) return;
          msg.textContent = t;
          await sleep(rand(650, 1400));
        }
        if (run !== myRun) return;
        think.remove();

        const card = document.createElement('div');
        card.className = 'demo-image';

        const hex = document.createElement('div');
        hex.className = 'demo-image-hex';
        let hs = (s.seed ?? 1) >>> 0;
        const nextByte = () => { hs = (hs * 1664525 + 1013904223) >>> 0; return (hs >>> 16) & 0xff; };
        let hexStr = '';
        for (let i = 0; i < 14; i++) hexStr += '0x' + nextByte().toString(16).toUpperCase().padStart(2, '0') + ' ';
        hex.textContent = hexStr + '…';
        card.appendChild(hex);

        const cap = document.createElement('div');
        cap.className = 'demo-image-cap';
        cap.textContent = 'DEX bytecode → 8-bit grey-scale image (128 × 128)';
        card.appendChild(cap);

        const canvas = document.createElement('canvas');
        canvas.width = 128;
        canvas.height = 128;
        canvas.className = 'demo-image-canvas';
        const canvasAlternative = `Generated grayscale DEX bytecode image for ${s.label}.`;
        canvas.setAttribute('role', 'img');
        canvas.setAttribute('aria-label', canvasAlternative);
        canvas.textContent = canvasAlternative;
        card.appendChild(canvas);
        stage.appendChild(card);
        drawDex(canvas, (s.seed ?? 1) >>> 0);

        const arrow = document.createElement('div');
        arrow.className = 'demo-image-cap';
        arrow.textContent = '↓  fed to the 1-D CNN';
        card.appendChild(arrow);
      }

      async function play(i: number) {
        const myRun = ++run;
        const s = demoData.scenarios[i];
        taskBtns.forEach((button, index) => {
          const selected = index === i;
          button.classList.toggle('active', selected);
          button.setAttribute('aria-pressed', String(selected));
        });

        stage.replaceChildren();
        stage.setAttribute('aria-busy', 'true');
        if (demoData.style === 'terminal') {
          await playTerminal(myRun, s);
        } else if (demoData.style === 'patch') {
          await playPatch(myRun, s);
        } else if (demoData.style === 'image') {
          await playImage(myRun, s);
        } else {
          await playLlm(myRun, s);
        }
        if (run !== myRun) return;

        if (s.verdictAnswer) {
          await sleep(300);
          if (run !== myRun) return;
          const bad =
            s.verdictKind === 'incorrect' ||
            s.verdictKind === 'malware' ||
            s.verdictKind === 'memorized';
          const v = document.createElement('div');
          v.className = 'demo-verdict ' + (bad ? 'bad' : 'good');
          const ans = document.createElement('span');
          ans.className = 'demo-verdict-answer';
          const answer = document.createElement('b');
          answer.textContent = s.verdictAnswer;
          ans.appendChild(createVerdictIcon(bad));
          ans.appendChild(answer);
          v.appendChild(ans);
          if (s.verdictLabel) {
            const tag = document.createElement('span');
            tag.className = 'demo-verdict-tag';
            tag.textContent = s.verdictLabel;
            v.appendChild(tag);
          }
          stage.appendChild(v);
        }

        if (s.explanation) {
          if (run !== myRun) return;
          await sleep(350);
          const exp = document.createElement('div');
          exp.className = 'demo-explanation';
          exp.innerHTML =
            '<svg class="demo-exp-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 18h6"/><path d="M10 21h4"/><path d="M12 3a6 6 0 0 0-3.6 10.8c.5.4.9 1 1 1.7l.1.5h5l.1-.5c.1-.7.5-1.3 1-1.7A6 6 0 0 0 12 3z"/></svg>';
          const txt = document.createElement('span');
          txt.textContent = s.explanation;
          exp.appendChild(txt);
          stage.appendChild(exp);
        }

        if (run === myRun) stage.setAttribute('aria-busy', 'false');
      }

      taskBtns.forEach((b, i) => b.addEventListener('click', () => play(i)));
    }

    function onVisible(el: Element, cb: () => void, threshold = 0.5) {
      if (!('IntersectionObserver' in window)) {
        cb();
        return;
      }

      let done = false;
      const io = new IntersectionObserver(
        (entries) => {
          if (entries[0]?.isIntersecting && !done) {
            done = true;
            cb();
            io.disconnect();
          }
        },
        { threshold }
      );
      io.observe(el);
    }

    const nums = document.querySelectorAll<HTMLElement>('.ds-stat-num');
    const fmt = new Intl.NumberFormat('en-US', { maximumFractionDigits: 20 });

    function countUp(el: HTMLElement) {
      const targetText = el.dataset.target ?? '0';
      const target = Number(targetText);
      const suffix = el.dataset.suffix ?? '';
      const finalValue = fmt.format(target) + suffix;
      if (!Number.isFinite(target) || el.dataset.animate === 'false' || prefersReducedMotion) {
        el.textContent = Number.isFinite(target) ? finalValue : '—';
        return;
      }

      const precision = Math.min(targetText.split('.')[1]?.length ?? 0, 20);
      const duration = 1200;
      const start = performance.now();
      el.textContent = fmt.format(0) + suffix;

      function step(now: number) {
        const progress = Math.min(1, (now - start) / duration);
        const eased = 1 - Math.pow(1 - progress, 3);
        const rawValue = target * eased;
        const value = precision > 0 ? Number(rawValue.toFixed(precision)) : Math.round(rawValue);
        el.textContent = fmt.format(value) + suffix;
        if (progress < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);

      // Guarantee the exact final value if rAF was paused in a background tab.
      setTimeout(() => {
        el.textContent = finalValue;
      }, duration + 400);
    }

    const statsEl = document.querySelector('.ds-stats');
    if (statsEl) onVisible(statsEl, () => nums.forEach(countUp), 0.6);

    const copyUsageBtn = document.getElementById('ds-copy-usage');
    const usageCode = document.getElementById('ds-usage-code');
    copyUsageBtn?.addEventListener('click', async () => {
      await navigator.clipboard.writeText(usageCode?.textContent ?? '');
      copyUsageBtn.textContent = 'Copied';
      setTimeout(() => (copyUsageBtn.textContent = 'Copy'), 1500);
    });

    const dsBox = document.getElementById('ds-sample');
    if (dsBox) {
      const ds = JSON.parse(dsBox.dataset.dataset ?? '{}');
      const body = document.getElementById('ds-sample-body')!;
      const shuffleBtn = document.getElementById('ds-shuffle');
      let drawRun = 0;

      async function draw() {
        const myRun = ++drawRun;
        const pool = [...ds.samples];
        for (let i = pool.length - 1; i > 0; i--) {
          const j = Math.floor(Math.random() * (i + 1));
          [pool[i], pool[j]] = [pool[j], pool[i]];
        }
        const rows = pool.slice(0, Math.min(ds.sampleCount ?? 8, pool.length));

        body.replaceChildren();
        if (ds.sampleHeader) {
          const h = document.createElement('code');
          h.className = 'ds-row ds-row-header';
          h.textContent = ds.sampleHeader;
          body.appendChild(h);
        }
        for (const r of rows) {
          if (drawRun !== myRun) return;
          const line = document.createElement('code');
          line.className = 'ds-row';
          line.textContent = r;
          body.appendChild(line);
          await sleep(rand(60, 150));
        }
      }

      shuffleBtn?.addEventListener('click', draw);
      onVisible(dsBox, draw, 0.2);
    }
  </script>
</Base>
