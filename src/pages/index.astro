---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ArtifactCard from '../components/ArtifactCard.astro';

const artifacts = (await getCollection('artifacts')).sort((a, b) => {
  const ya = a.data.paper?.year ?? 0;
  const yb = b.data.paper?.year ?? 0;
  return yb - ya || a.data.name.localeCompare(b.data.name);
});

const types = ['all', 'dataset', 'tool', 'library', 'demo', 'benchmark'];
const labels: Record<string, string> = {
  all: 'All',
  dataset: 'Datasets',
  tool: 'Tools',
  library: 'Libraries',
  demo: 'Demos',
  benchmark: 'Benchmarks',
};
const counts = Object.fromEntries(
  types.map((t) => [
    t,
    t === 'all' ? artifacts.length : artifacts.filter((a) => a.data.type === t).length,
  ])
);

const byArea = new Map<string, typeof artifacts>();
for (const artifact of artifacts) {
  const area = artifact.data.area;
  if (!byArea.has(area)) byArea.set(area, []);
  byArea.get(area)!.push(artifact);
}
const firstArea = 'LLMs for Software Engineering';
const orderedAreas = [...byArea.keys()].sort((a, b) => {
  if (a === firstArea) return -1;
  if (b === firstArea) return 1;
  if (a === 'Other') return 1;
  if (b === 'Other') return -1;
  return a.localeCompare(b, 'en');
});

const tagCounts = new Map<string, number>();
for (const artifact of artifacts) {
  for (const t of artifact.data.tags) tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
}
const topTags = [...tagCounts.entries()]
  .filter(([, n]) => n >= 2)
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .slice(0, 10)
  .map(([t]) => t);

const plurals: Record<string, [string, string]> = {
  all: ['artifact', 'artifacts'],
  dataset: ['dataset', 'datasets'],
  tool: ['tool', 'tools'],
  library: ['library', 'libraries'],
  demo: ['demo', 'demos'],
  benchmark: ['benchmark', 'benchmarks'],
};
const stats = types
  .filter((t) => counts[t] > 0)
  .map((t) => ({ count: counts[t], label: plurals[t][counts[t] === 1 ? 0 : 1] }));
---

<Base title="TruX Artifacts — Research artifacts for the community">
  <div class="hero-band">
    <div class="container hero-inner">
      <div class="hero-text">
        <h1>Research artifacts</h1>
        <p>
          Datasets, tools, and demonstrations from the Trustworthy Software Engineering (TruX)
          group at SnT, University of Luxembourg — open and reusable for the research community.
        </p>
        <div class="hero-stats">
          {stats.map((s) => (
            <div class="stat">
              <span class="stat-num" data-target={s.count}>0</span>
              <span class="stat-label">{s.label}</span>
            </div>
          ))}
        </div>
      </div>
      <div class="hero-actions">
        <a class="btn-hero" href="https://github.com/Trustworthy-Software" target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.387.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.09-.745.083-.73.083-.73 1.205.084 1.84 1.236 1.84 1.236 1.07 1.835 2.807 1.305 3.492.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12z"/></svg>
          Our GitHub organization
        </a>
      </div>
    </div>
  </div>

  <div class="container">
  <div class="toolbar">
    <input type="search" id="search" placeholder="Search artifacts, papers, topics…" aria-label="Search artifacts" />
    {types.map((t) => (
      <button
        class={`chip${t === 'all' ? ' active' : ''}`}
        data-filter={t}
        style={counts[t] === 0 && t !== 'all' ? 'display:none' : undefined}
      >
        {labels[t]} ({counts[t]})
      </button>
    ))}
  </div>

  <div class="tags-row">
    <span class="tags-row-label">Topics</span>
    {topTags.map((t) => (
      <button class="chip chip-tag" data-tag={t}>{t}</button>
    ))}
  </div>

  {orderedAreas.map((area) => (
    <section class="area-section">
      <h2 class="area-title">{area} <span class="area-count">{byArea.get(area)!.length}</span></h2>
      <div class="grid">
        {byArea.get(area)!.map((artifact) => <ArtifactCard artifact={artifact} />)}
      </div>
    </section>
  ))}

  <div class="empty" id="empty">No artifacts match your search.</div>
  </div>

  <script>
    const search = document.getElementById('search') as HTMLInputElement;
    const chips = document.querySelectorAll<HTMLButtonElement>('.chip');
    const cards = document.querySelectorAll<HTMLElement>('.card');
    const empty = document.getElementById('empty')!;
    let activeType = 'all';

    const sections = document.querySelectorAll<HTMLElement>('.area-section');
    const tagChips = document.querySelectorAll<HTMLButtonElement>('.chip-tag');
    let activeTag: string | null = null;

    function apply() {
      const q = search.value.trim().toLowerCase();
      let visible = 0;
      cards.forEach((card) => {
        const typeOk = activeType === 'all' || card.dataset.type === activeType;
        const textOk = !q || (card.dataset.search ?? '').includes(q);
        const tagOk = !activeTag || (card.dataset.tags ?? '').split(',').includes(activeTag);
        const show = typeOk && textOk && tagOk;
        card.style.display = show ? '' : 'none';
        if (show) visible++;
      });
      sections.forEach((section) => {
        const any = [...section.querySelectorAll<HTMLElement>('.card')].some(
          (c) => c.style.display !== 'none'
        );
        section.style.display = any ? '' : 'none';
      });
      empty.style.display = visible === 0 ? 'block' : 'none';
    }

    search.addEventListener('input', apply);
    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        chips.forEach((c) => c.classList.remove('active'));
        chip.classList.add('active');
        activeType = chip.dataset.filter ?? 'all';
        apply();
      });
    });

    tagChips.forEach((chip) => {
      chip.addEventListener('click', () => {
        const tag = chip.dataset.tag ?? null;
        activeTag = activeTag === tag ? null : tag;
        tagChips.forEach((c) => c.classList.toggle('active', c.dataset.tag === activeTag));
        apply();
      });
    });

    const topic = new URLSearchParams(window.location.search).get('topic');
    if (topic) {
      const chip = [...tagChips].find((c) => c.dataset.tag === topic);
      if (chip) {
        chip.click();
      } else {
        search.value = topic;
        apply();
        search.focus();
      }
    }

    const fmt = new Intl.NumberFormat('en-US');
    function countUp(el: HTMLElement) {
      const target = Number(el.dataset.target ?? '0');
      const dur = 1100;
      const start = performance.now();
      function step(now: number) {
        const t = Math.min(1, (now - start) / dur);
        const eased = 1 - Math.pow(1 - t, 3);
        el.textContent = fmt.format(Math.round(target * eased));
        if (t < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
      setTimeout(() => (el.textContent = fmt.format(target)), dur + 400);
    }
    const heroNums = document.querySelectorAll<HTMLElement>('.stat-num');
    if (heroNums.length) {
      const heroStats = document.querySelector('.hero-stats')!;
      let counted = false;
      const io = new IntersectionObserver(
        (entries) => {
          if (entries[0].isIntersecting && !counted) {
            counted = true;
            heroNums.forEach(countUp);
            io.disconnect();
          }
        },
        { threshold: 0.5 }
      );
      io.observe(heroStats);
    }
  </script>
</Base>
