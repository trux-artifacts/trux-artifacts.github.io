---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ArtifactCard from '../components/ArtifactCard.astro';
import {
  ARTIFACT_FILTERS,
  ARTIFACT_TYPE_LABELS,
  ARTIFACT_TYPE_NOUNS,
} from '../data/taxonomy';

const artifacts = (await getCollection('artifacts')).sort((a, b) => {
  const added = b.data.addedAt.localeCompare(a.data.addedAt);
  const ya = a.data.paper?.year ?? 0;
  const yb = b.data.paper?.year ?? 0;
  return added || yb - ya || a.data.name.localeCompare(b.data.name);
});

const PAGE_SIZE = 12;

const types = ARTIFACT_FILTERS;
const labels = ARTIFACT_TYPE_LABELS;
const counts = Object.fromEntries(
  types.map((t) => [
    t,
    t === 'all' ? artifacts.length : artifacts.filter((a) => a.data.type === t).length,
  ])
);

const byArea = new Map<string, typeof artifacts>();
for (const artifact of artifacts) {
  const area = artifact.data.area;
  if (!byArea.has(area)) byArea.set(area, []);
  byArea.get(area)!.push(artifact);
}
const firstArea = 'LLMs for Software Engineering';
const orderedAreas = [...byArea.keys()].sort((a, b) => {
  if (a === firstArea) return -1;
  if (b === firstArea) return 1;
  if (a === 'Other') return 1;
  if (b === 'Other') return -1;
  return a.localeCompare(b, 'en');
});

const tagCounts = new Map<string, number>();
for (const artifact of artifacts) {
  for (const t of artifact.data.tags) tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
}
const allTags = [...tagCounts.entries()]
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .map(([name, count]) => ({ name, count }));

const stats = types
  .filter((t) => counts[t] > 0)
  .map((t) => ({
    count: counts[t],
    label: ARTIFACT_TYPE_NOUNS[t][counts[t] === 1 ? 0 : 1],
  }));
---

<Base title="TruX Artifacts — Research artifacts for the community">
  <div class="hero-band">
    <div class="container hero-inner">
      <div class="hero-text">
        <h1>Research artifacts</h1>
        <p>
          Datasets, tools, and demonstrations from the Trustworthy Software Engineering (TruX)
          group at SnT, University of Luxembourg — open and reusable for the research community.
        </p>
        <div class="hero-stats">
          {stats.map((s) => (
            <div class="stat">
              <span class="stat-num" data-target={s.count}>{s.count}</span>
              <span class="stat-label">{s.label}</span>
            </div>
          ))}
        </div>
      </div>
      <div class="hero-actions">
        <a class="btn-hero" href="https://github.com/trux-artifacts" target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.387.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.09-.745.083-.73.083-.73 1.205.084 1.84 1.236 1.84 1.236 1.07 1.835 2.807 1.305 3.492.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12z"/></svg>
          Our GitHub organization
        </a>
      </div>
    </div>
  </div>

  <div class="container catalog-container">
    <section class="catalog-controls" aria-label="Artifact filters">
      <div class="toolbar">
        <label class="search-control" for="search">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m21 20-4.35-4.35a8 8 0 1 0-1.41 1.41L19.59 21 21 20ZM5 11a6 6 0 1 1 12 0 6 6 0 0 1-12 0Z"/></svg>
          <input
            type="search"
            id="search"
            placeholder="Search artifacts, papers, authors…"
            aria-label="Search artifacts"
            aria-controls="artifact-catalog"
            autocomplete="off"
          />
        </label>

        <div class="topic-picker" id="topic-picker">
          <button
            class="topic-trigger"
            id="topic-trigger"
            type="button"
            aria-expanded="false"
            aria-haspopup="dialog"
            aria-controls="topic-menu"
          >
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 6h16v2H4V6Zm3 5h10v2H7v-2Zm3 5h4v2h-4v-2Z"/></svg>
            <span>Topics</span>
            <span class="topic-trigger-value" id="topic-trigger-value">All topics</span>
            <span class="topic-selection-count" id="topic-selection-count" hidden>0</span>
            <svg class="topic-chevron" viewBox="0 0 20 20" aria-hidden="true"><path d="m5.5 7.5 4.5 4 4.5-4 1 1.1-5.5 5-5.5-5 1-1.1Z"/></svg>
          </button>

          <div class="topic-menu" id="topic-menu" role="dialog" aria-label="Choose topics" hidden>
            <div class="topic-menu-heading">
              <div>
                <strong>Filter by topic</strong>
                <span>{allTags.length} topics · match any selected topic</span>
              </div>
              <button class="topic-menu-close" id="topic-menu-close" type="button" aria-label="Close topics">×</button>
            </div>
            <label class="topic-search-control" for="topic-search">
              <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m21 20-4.35-4.35a8 8 0 1 0-1.41 1.41L19.59 21 21 20ZM5 11a6 6 0 1 1 12 0 6 6 0 0 1-12 0Z"/></svg>
              <input id="topic-search" type="search" placeholder="Find a topic…" aria-label="Search topics" autocomplete="off" />
            </label>
            <div class="topic-options" id="topic-options" aria-label="Available topics">
              {allTags.map(({ name, count }) => (
                <button
                  class="topic-option"
                  type="button"
                  data-tag={name}
                  aria-pressed="false"
                  aria-controls="artifact-catalog"
                >
                  <span>{name}</span>
                  <span class="topic-option-count">{count}</span>
                </button>
              ))}
            </div>
            <p class="topic-menu-empty" id="topic-menu-empty" hidden>No matching topics.</p>
            <div class="topic-menu-footer">
              <button class="topic-clear" id="clear-topics" type="button" hidden>Clear topics</button>
              <button class="topic-done" id="topic-done" type="button">Done</button>
            </div>
          </div>
        </div>
      </div>

      <div class="type-filter-row">
        <span class="filter-row-label">Artifact type</span>
        <div class="type-filters" role="group" aria-label="Filter by artifact type">
          {types.map((t) => (
            <button
              type="button"
              class={`chip chip-type${t === 'all' ? ' active' : ''}`}
              data-filter={t}
              data-label={labels[t]}
              aria-pressed={t === 'all' ? 'true' : 'false'}
              aria-controls="artifact-catalog"
              hidden={counts[t] === 0 && t !== 'all'}
            >
              {labels[t]} <span>{counts[t]}</span>
            </button>
          ))}
        </div>
      </div>

      <div class="active-topics-row" id="active-topics-row" hidden>
        <span class="filter-row-label">Selected topics</span>
        <div class="active-topics" id="active-topics"></div>
      </div>
    </section>

    <div class="filter-status-row">
      <p class="result-status" id="result-status" role="status" aria-live="polite" aria-atomic="true">
        {artifacts.length} {artifacts.length === 1 ? 'artifact' : 'artifacts'} · sorted by recently added
      </p>
      <button class="clear-filters" id="clear-filters" type="button" hidden>Reset all filters</button>
    </div>

    <div class="catalog-layout">
      <aside class="area-panel" aria-labelledby="area-panel-title">
        <div class="area-panel-heading">
          <span class="catalog-eyebrow">Browse by</span>
          <h2 id="area-panel-title">Research areas</h2>
        </div>
        <div class="area-nav" role="group" aria-label="Filter by research area">
          <button class="area-filter active" type="button" data-area="" aria-pressed="true">
            <span>All research areas</span>
            <span class="area-filter-count">{artifacts.length}</span>
          </button>
          {orderedAreas.map((area) => (
            <button class="area-filter" type="button" data-area={area} aria-pressed="false">
              <span>{area}</span>
              <span class="area-filter-count">{byArea.get(area)!.length}</span>
            </button>
          ))}
        </div>

        <label class="area-select-control" for="area-select">
          <span>Research area</span>
          <select id="area-select" aria-controls="artifact-catalog">
            <option value="" data-area-label="All research areas">All research areas ({artifacts.length})</option>
            {orderedAreas.map((area) => (
              <option value={area} data-area-label={area}>{area} ({byArea.get(area)!.length})</option>
            ))}
          </select>
        </label>
      </aside>

      <section class="catalog-results" id="catalog-results" aria-labelledby="catalog-title">
        <header class="catalog-results-heading">
          <div>
            <span class="catalog-eyebrow">Artifact catalog</span>
            <h2 id="catalog-title" tabindex="-1">All research areas</h2>
          </div>
          <label class="sort-control" for="sort-select">
            <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M4 5h8v2H4V5Zm0 4h6v2H4V9Zm0 4h4v2H4v-2Zm10-8h2v7.2l1.6-1.6L19 12l-4 4-4-4 1.4-1.4 1.6 1.6V5Z"/></svg>
            <span>Sort by</span>
            <select id="sort-select" aria-label="Sort artifacts by" aria-controls="artifact-catalog">
              <option value="recent">Recently added</option>
              <option value="publication">Publication year</option>
              <option value="name">Name A–Z</option>
            </select>
          </label>
        </header>

        <div class="grid" id="artifact-catalog" data-page-size={PAGE_SIZE}>
          {artifacts.map((artifact) => <ArtifactCard artifact={artifact} />)}
        </div>

        <div class="empty" id="empty" hidden>
          <strong>No artifacts found</strong>
          <span>Try another search or remove some filters.</span>
          <button id="empty-reset" type="button">Reset all filters</button>
        </div>

        <nav class="pagination" id="pagination" aria-label="Artifact pages" hidden>
          <button class="pagination-step" id="previous-page" type="button">
            <span aria-hidden="true">←</span> Previous
          </button>
          <div class="page-numbers" id="page-numbers"></div>
          <span class="mobile-page-status" id="mobile-page-status"></span>
          <button class="pagination-step" id="next-page" type="button">
            Next <span aria-hidden="true">→</span>
          </button>
        </nav>
      </section>
    </div>
  </div>

  <script>
    const search = document.getElementById('search') as HTMLInputElement;
    const typeChips = document.querySelectorAll<HTMLButtonElement>('.chip-type');
    const areaFilters = document.querySelectorAll<HTMLButtonElement>('.area-filter');
    const areaSelect = document.getElementById('area-select') as HTMLSelectElement;
    const sortSelect = document.getElementById('sort-select') as HTMLSelectElement;
    const topicPicker = document.getElementById('topic-picker')!;
    const topicTrigger = document.getElementById('topic-trigger') as HTMLButtonElement;
    const topicTriggerValue = document.getElementById('topic-trigger-value')!;
    const topicSelectionCount = document.getElementById('topic-selection-count')!;
    const topicMenu = document.getElementById('topic-menu')!;
    const topicMenuClose = document.getElementById('topic-menu-close') as HTMLButtonElement;
    const topicSearch = document.getElementById('topic-search') as HTMLInputElement;
    const topicOptions = document.querySelectorAll<HTMLButtonElement>('.topic-option');
    const topicMenuEmpty = document.getElementById('topic-menu-empty')!;
    const topicDone = document.getElementById('topic-done') as HTMLButtonElement;
    const clearTopics = document.getElementById('clear-topics') as HTMLButtonElement;
    const activeTopicsRow = document.getElementById('active-topics-row')!;
    const activeTopics = document.getElementById('active-topics')!;
    const cards = [...document.querySelectorAll<HTMLElement>('.card')];
    const recentOrder = new Map(cards.map((card, index) => [card, index]));
    const empty = document.getElementById('empty')!;
    const emptyReset = document.getElementById('empty-reset') as HTMLButtonElement;
    const catalog = document.getElementById('artifact-catalog')!;
    const catalogResults = document.getElementById('catalog-results')!;
    const catalogTitle = document.getElementById('catalog-title')!;
    const pageSize = Math.max(1, Number(catalog.dataset.pageSize ?? '12') || 12);
    const resultStatus = document.getElementById('result-status')!;
    const clearFilters = document.getElementById('clear-filters') as HTMLButtonElement;
    const pagination = document.getElementById('pagination')!;
    const previousPage = document.getElementById('previous-page') as HTMLButtonElement;
    const nextPage = document.getElementById('next-page') as HTMLButtonElement;
    const pageNumbers = document.getElementById('page-numbers')!;
    const mobilePageStatus = document.getElementById('mobile-page-status')!;
    const cardTags = new Map<HTMLElement, string[]>();
    cards.forEach((card) => {
      try {
        const parsed: unknown = JSON.parse(card.dataset.tags ?? '[]');
        cardTags.set(
          card,
          Array.isArray(parsed) ? parsed.filter((tag): tag is string => typeof tag === 'string') : []
        );
      } catch {
        cardTags.set(card, []);
      }
    });

    const validTypes = new Set([...typeChips].map((chip) => chip.dataset.filter ?? 'all'));
    const validAreas = new Set([...areaFilters].map((filter) => filter.dataset.area ?? ''));
    const validTags = new Set([...topicOptions].map((option) => option.dataset.tag ?? ''));
    const validSorts = new Set(['recent', 'publication', 'name']);
    const sortLabels: Record<string, string> = {
      recent: 'recently added',
      publication: 'publication year',
      name: 'name A–Z',
    };
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    let activeType = 'all';
    let activeArea = '';
    let activeSort = 'recent';
    let selectedTopics = new Set<string>();
    let currentPage = 1;

    function normalize(value: string) {
      return value
        .normalize('NFD')
        .replace(/[\u0300-\u036f]/g, '')
        .toLowerCase();
    }

    function setActiveType(type: string) {
      activeType = type;
      typeChips.forEach((chip) => {
        const active = chip.dataset.filter === activeType;
        chip.classList.toggle('active', active);
        chip.setAttribute('aria-pressed', String(active));
      });
    }

    function setTopicMenu(open: boolean) {
      topicMenu.hidden = !open;
      topicTrigger.setAttribute('aria-expanded', String(open));
      topicPicker.classList.toggle('open', open);
      if (open) {
        window.setTimeout(() => topicSearch.focus(), 0);
      } else {
        topicSearch.value = '';
        filterTopicOptions();
      }
    }

    function filterTopicOptions() {
      const query = normalize(topicSearch.value.trim());
      let visible = 0;
      topicOptions.forEach((option) => {
        const matches = !query || normalize(option.dataset.tag ?? '').includes(query);
        option.hidden = !matches;
        if (matches) visible++;
      });
      topicMenuEmpty.hidden = visible !== 0;
    }

    function renderActiveTopics() {
      activeTopics.replaceChildren();
      const sortedTopics = [...selectedTopics].sort((a, b) => a.localeCompare(b));
      sortedTopics.slice(0, 4).forEach((tag) => {
        const chip = document.createElement('button');
        chip.type = 'button';
        chip.className = 'active-topic-chip';
        chip.setAttribute('aria-label', `Remove topic ${tag}`);
        const label = document.createElement('span');
        label.textContent = tag;
        const remove = document.createElement('span');
        remove.setAttribute('aria-hidden', 'true');
        remove.textContent = '×';
        chip.append(label, remove);
        chip.addEventListener('click', () => {
          selectedTopics.delete(tag);
          currentPage = 1;
          apply('push');
          topicTrigger.focus();
        });
        activeTopics.append(chip);
      });
      if (sortedTopics.length > 4) {
        const more = document.createElement('button');
        more.type = 'button';
        more.className = 'active-topic-more';
        more.textContent = `+${sortedTopics.length - 4} more`;
        more.setAttribute('aria-label', `Manage ${sortedTopics.length - 4} additional selected topics`);
        more.addEventListener('click', (event) => {
          event.stopPropagation();
          setTopicMenu(true);
        });
        activeTopics.append(more);
      }
      activeTopicsRow.hidden = sortedTopics.length === 0;
    }

    function syncControls() {
      setActiveType(activeType);
      areaFilters.forEach((filter) => {
        const active = (filter.dataset.area ?? '') === activeArea;
        filter.classList.toggle('active', active);
        filter.setAttribute('aria-pressed', String(active));
      });
      areaSelect.value = activeArea;
      sortSelect.value = activeSort;
      topicOptions.forEach((option) => {
        const active = selectedTopics.has(option.dataset.tag ?? '');
        option.classList.toggle('active', active);
        option.setAttribute('aria-pressed', String(active));
      });
      const topicCount = selectedTopics.size;
      topicSelectionCount.textContent = String(topicCount);
      topicSelectionCount.hidden = topicCount === 0;
      clearTopics.hidden = topicCount === 0;
      topicTriggerValue.textContent = topicCount === 0
        ? 'All topics'
        : topicCount === 1
          ? [...selectedTopics][0]
          : `${topicCount} selected`;
      renderActiveTopics();
    }

    function writeUrl(mode: 'push' | 'replace' | 'none') {
      if (mode === 'none') return;
      const params = new URLSearchParams();
      const query = search.value.trim();
      if (query) params.set('q', query);
      if (activeType !== 'all') params.set('type', activeType);
      if (activeArea) params.set('area', activeArea);
      if (activeSort !== 'recent') params.set('sort', activeSort);
      [...selectedTopics].sort((a, b) => a.localeCompare(b)).forEach((tag) => params.append('topic', tag));
      if (currentPage > 1) params.set('page', String(currentPage));
      const nextUrl = `${window.location.pathname}${params.size ? `?${params.toString()}` : ''}`;
      window.history[mode === 'push' ? 'pushState' : 'replaceState'](null, '', nextUrl);
    }

    function pageSequence(pageCount: number) {
      const pages = new Set([1, pageCount, currentPage - 1, currentPage, currentPage + 1]);
      const validPages = [...pages].filter((page) => page >= 1 && page <= pageCount).sort((a, b) => a - b);
      const sequence: Array<number | 'ellipsis'> = [];
      validPages.forEach((page, index) => {
        if (index > 0 && page - validPages[index - 1] > 1) sequence.push('ellipsis');
        sequence.push(page);
      });
      return sequence;
    }

    function goToPage(page: number) {
      currentPage = page;
      apply('push');
      catalogResults.scrollIntoView({ behavior: reduceMotion ? 'auto' : 'smooth', block: 'start' });
      window.setTimeout(() => catalogTitle.focus({ preventScroll: true }), reduceMotion ? 0 : 250);
    }

    function renderPagination(pageCount: number) {
      pagination.hidden = pageCount <= 1;
      previousPage.disabled = currentPage <= 1;
      nextPage.disabled = currentPage >= pageCount;
      mobilePageStatus.textContent = `Page ${currentPage} of ${Math.max(1, pageCount)}`;
      pageNumbers.replaceChildren();
      pageSequence(pageCount).forEach((item) => {
        if (item === 'ellipsis') {
          const ellipsis = document.createElement('span');
          ellipsis.className = 'page-ellipsis';
          ellipsis.textContent = '…';
          ellipsis.setAttribute('aria-hidden', 'true');
          pageNumbers.append(ellipsis);
          return;
        }
        const button = document.createElement('button');
        button.type = 'button';
        button.className = 'page-number';
        button.textContent = String(item);
        button.setAttribute('aria-label', `Go to page ${item}`);
        if (item === currentPage) button.setAttribute('aria-current', 'page');
        button.addEventListener('click', () => goToPage(item));
        pageNumbers.append(button);
      });
    }

    function compareCards(a: HTMLElement, b: HTMLElement) {
      const nameOrder = (a.dataset.name ?? '').localeCompare(b.dataset.name ?? '', 'en', {
        sensitivity: 'base',
      });
      const addedOrder = (recentOrder.get(a) ?? 0) - (recentOrder.get(b) ?? 0);
      const publicationOrder = Number(b.dataset.paperYear ?? '0') - Number(a.dataset.paperYear ?? '0');

      if (activeSort === 'name') return nameOrder;
      if (activeSort === 'publication') return publicationOrder || addedOrder || nameOrder;
      return addedOrder || publicationOrder || nameOrder;
    }

    function apply(historyMode: 'push' | 'replace' | 'none' = 'replace') {
      const rawQuery = search.value.trim();
      const q = normalize(rawQuery);
      const matchingCards: HTMLElement[] = [];
      const availableByArea = new Map<string, number>();
      let availableAcrossAreas = 0;

      cards.sort(compareCards);
      cards.forEach((card) => catalog.append(card));

      cards.forEach((card) => {
        const typeOk = activeType === 'all' || card.dataset.type === activeType;
        const textOk = !q || (card.dataset.search ?? '').includes(q);
        const tags = cardTags.get(card) ?? [];
        const tagOk = selectedTopics.size === 0 || tags.some((tag) => selectedTopics.has(tag));
        const baseMatch = typeOk && textOk && tagOk;
        const cardArea = card.dataset.area ?? '';
        if (baseMatch) {
          availableAcrossAreas++;
          availableByArea.set(cardArea, (availableByArea.get(cardArea) ?? 0) + 1);
          if (!activeArea || cardArea === activeArea) matchingCards.push(card);
        }
      });

      areaFilters.forEach((filter) => {
        const area = filter.dataset.area ?? '';
        const count = area ? (availableByArea.get(area) ?? 0) : availableAcrossAreas;
        const countElement = filter.querySelector<HTMLElement>('.area-filter-count');
        if (countElement) countElement.textContent = String(count);
      });
      [...areaSelect.options].forEach((option) => {
        const area = option.value;
        const count = area ? (availableByArea.get(area) ?? 0) : availableAcrossAreas;
        option.textContent = `${option.dataset.areaLabel ?? area} (${count})`;
      });

      const matching = matchingCards.length;
      const pageCount = Math.ceil(matching / pageSize);
      currentPage = pageCount === 0 ? 1 : Math.min(Math.max(1, currentPage), pageCount);
      const firstIndex = (currentPage - 1) * pageSize;
      const visibleCards = new Set(matchingCards.slice(firstIndex, firstIndex + pageSize));
      cards.forEach((card) => (card.hidden = !visibleCards.has(card)));

      const firstResult = matching === 0 ? 0 : firstIndex + 1;
      const lastResult = Math.min(firstIndex + pageSize, matching);
      empty.hidden = matching !== 0;
      catalog.hidden = matching === 0;
      catalogTitle.textContent = activeArea || 'All research areas';
      const constraints: string[] = [];
      if (activeType !== 'all') {
        const chip = [...typeChips].find((item) => item.dataset.filter === activeType);
        constraints.push(chip?.dataset.label ?? activeType);
      }
      if (activeArea) constraints.push(activeArea);
      if (selectedTopics.size) constraints.push(`${selectedTopics.size} ${selectedTopics.size === 1 ? 'topic' : 'topics'}`);
      if (rawQuery) constraints.push(`“${rawQuery}”`);
      const suffix = constraints.length ? ` · ${constraints.join(' · ')}` : '';
      const sortLabel = sortLabels[activeSort] ?? sortLabels.recent;
      resultStatus.textContent = matching === 0
        ? `No artifacts found${suffix}`
        : `Showing ${firstResult}–${lastResult} of ${matching} ${matching === 1 ? 'artifact' : 'artifacts'}${suffix} · sorted by ${sortLabel}`;
      clearFilters.hidden = constraints.length === 0;
      syncControls();
      renderPagination(pageCount);
      writeUrl(historyMode);
    }

    function resetFilters() {
      search.value = '';
      activeType = 'all';
      activeArea = '';
      selectedTopics.clear();
      currentPage = 1;
      setTopicMenu(false);
      apply('push');
      search.focus();
    }

    function readUrlState() {
      const params = new URLSearchParams(window.location.search);
      const requestedType = params.get('type') ?? 'all';
      const requestedArea = params.get('area') ?? '';
      const requestedSort = params.get('sort') ?? 'recent';
      activeType = validTypes.has(requestedType) ? requestedType : 'all';
      activeArea = validAreas.has(requestedArea) ? requestedArea : '';
      activeSort = validSorts.has(requestedSort) ? requestedSort : 'recent';
      selectedTopics = new Set(params.getAll('topic').filter((tag) => validTags.has(tag)));
      search.value = params.get('q') ?? '';
      const requestedPage = Number.parseInt(params.get('page') ?? '1', 10);
      currentPage = Number.isFinite(requestedPage) ? Math.max(1, requestedPage) : 1;
    }

    search.addEventListener('input', () => {
      currentPage = 1;
      apply('replace');
    });
    typeChips.forEach((chip) => {
      chip.addEventListener('click', () => {
        activeType = chip.dataset.filter ?? 'all';
        currentPage = 1;
        apply('push');
      });
    });

    areaFilters.forEach((filter) => {
      filter.addEventListener('click', () => {
        activeArea = filter.dataset.area ?? '';
        currentPage = 1;
        apply('push');
      });
    });

    areaSelect.addEventListener('change', () => {
      activeArea = areaSelect.value;
      currentPage = 1;
      apply('push');
    });

    sortSelect.addEventListener('change', () => {
      activeSort = validSorts.has(sortSelect.value) ? sortSelect.value : 'recent';
      currentPage = 1;
      apply('push');
    });

    topicTrigger.addEventListener('click', () => setTopicMenu(topicMenu.hidden));
    topicMenuClose.addEventListener('click', () => {
      setTopicMenu(false);
      topicTrigger.focus();
    });
    topicDone.addEventListener('click', () => {
      setTopicMenu(false);
      topicTrigger.focus();
    });
    topicSearch.addEventListener('input', filterTopicOptions);
    topicOptions.forEach((option) => {
      option.addEventListener('click', () => {
        const tag = option.dataset.tag ?? '';
        if (selectedTopics.has(tag)) selectedTopics.delete(tag);
        else selectedTopics.add(tag);
        currentPage = 1;
        apply('push');
      });
    });

    clearTopics.addEventListener('click', () => {
      selectedTopics.clear();
      currentPage = 1;
      apply('push');
      topicSearch.focus();
    });
    clearFilters.addEventListener('click', resetFilters);
    emptyReset.addEventListener('click', resetFilters);
    previousPage.addEventListener('click', () => goToPage(Math.max(1, currentPage - 1)));
    nextPage.addEventListener('click', () => goToPage(currentPage + 1));

    document.addEventListener('click', (event) => {
      if (!topicMenu.hidden && !topicPicker.contains(event.target as Node)) setTopicMenu(false);
    });
    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && !topicMenu.hidden) {
        setTopicMenu(false);
        topicTrigger.focus();
      }
    });
    window.addEventListener('popstate', () => {
      readUrlState();
      apply('none');
    });

    readUrlState();
    apply('replace');

    const fmt = new Intl.NumberFormat('en-US');

    function showFinalCount(el: HTMLElement) {
      el.textContent = fmt.format(Number(el.dataset.target ?? '0'));
    }

    function countUp(el: HTMLElement) {
      const target = Number(el.dataset.target ?? '0');
      if (reduceMotion) {
        showFinalCount(el);
        return;
      }
      el.textContent = '0';
      const dur = 1100;
      const start = performance.now();
      function step(now: number) {
        const t = Math.min(1, (now - start) / dur);
        const eased = 1 - Math.pow(1 - t, 3);
        el.textContent = fmt.format(Math.round(target * eased));
        if (t < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
      setTimeout(() => (el.textContent = fmt.format(target)), dur + 400);
    }
    const heroNums = document.querySelectorAll<HTMLElement>('.stat-num');
    if (heroNums.length && !reduceMotion && 'IntersectionObserver' in window) {
      const heroStats = document.querySelector('.hero-stats')!;
      let counted = false;
      const io = new IntersectionObserver(
        (entries) => {
          if (entries[0].isIntersecting && !counted) {
            counted = true;
            heroNums.forEach(countUp);
            io.disconnect();
          }
        },
        { threshold: 0.5 }
      );
      io.observe(heroStats);
    } else {
      heroNums.forEach(showFinalCount);
    }
  </script>
</Base>
