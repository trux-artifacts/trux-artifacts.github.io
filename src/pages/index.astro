---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ArtifactCard from '../components/ArtifactCard.astro';
import {
  ARTIFACT_FILTERS,
  ARTIFACT_TYPE_LABELS,
  ARTIFACT_TYPE_NOUNS,
} from '../data/taxonomy';

const artifacts = (await getCollection('artifacts')).sort((a, b) => {
  const ya = a.data.paper?.year ?? 0;
  const yb = b.data.paper?.year ?? 0;
  return yb - ya || a.data.name.localeCompare(b.data.name);
});

const types = ARTIFACT_FILTERS;
const labels = ARTIFACT_TYPE_LABELS;
const counts = Object.fromEntries(
  types.map((t) => [
    t,
    t === 'all' ? artifacts.length : artifacts.filter((a) => a.data.type === t).length,
  ])
);

const byArea = new Map<string, typeof artifacts>();
for (const artifact of artifacts) {
  const area = artifact.data.area;
  if (!byArea.has(area)) byArea.set(area, []);
  byArea.get(area)!.push(artifact);
}
const firstArea = 'LLMs for Software Engineering';
const orderedAreas = [...byArea.keys()].sort((a, b) => {
  if (a === firstArea) return -1;
  if (b === firstArea) return 1;
  if (a === 'Other') return 1;
  if (b === 'Other') return -1;
  return a.localeCompare(b, 'en');
});

const tagCounts = new Map<string, number>();
for (const artifact of artifacts) {
  for (const t of artifact.data.tags) tagCounts.set(t, (tagCounts.get(t) ?? 0) + 1);
}
const topTags = [...tagCounts.entries()]
  .filter(([, n]) => n >= 2)
  .sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))
  .slice(0, 10)
  .map(([t]) => t);

const stats = types
  .filter((t) => counts[t] > 0)
  .map((t) => ({
    count: counts[t],
    label: ARTIFACT_TYPE_NOUNS[t][counts[t] === 1 ? 0 : 1],
  }));
---

<Base title="TruX Artifacts — Research artifacts for the community">
  <div class="hero-band">
    <div class="container hero-inner">
      <div class="hero-text">
        <h1>Research artifacts</h1>
        <p>
          Datasets, tools, and demonstrations from the Trustworthy Software Engineering (TruX)
          group at SnT, University of Luxembourg — open and reusable for the research community.
        </p>
        <div class="hero-stats">
          {stats.map((s) => (
            <div class="stat">
              <span class="stat-num" data-target={s.count}>{s.count}</span>
              <span class="stat-label">{s.label}</span>
            </div>
          ))}
        </div>
      </div>
      <div class="hero-actions">
        <a class="btn-hero" href="https://github.com/trux-artifacts" target="_blank" rel="noopener noreferrer">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.387.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.387-1.333-1.756-1.333-1.756-1.09-.745.083-.73.083-.73 1.205.084 1.84 1.236 1.84 1.236 1.07 1.835 2.807 1.305 3.492.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12z"/></svg>
          Our GitHub organization
        </a>
      </div>
    </div>
  </div>

  <div class="container">
    <div class="toolbar">
      <input
        type="search"
        id="search"
        placeholder="Search artifacts, papers, topics…"
        aria-label="Search artifacts"
        aria-controls="artifact-catalog"
      />
      <div class="type-filters" role="group" aria-label="Filter by artifact type">
        {types.map((t) => (
          <button
            type="button"
            class={`chip chip-type${t === 'all' ? ' active' : ''}`}
            data-filter={t}
            data-label={labels[t]}
            aria-pressed={t === 'all' ? 'true' : 'false'}
            aria-controls="artifact-catalog"
            hidden={counts[t] === 0 && t !== 'all'}
          >
            {labels[t]} ({counts[t]})
          </button>
        ))}
      </div>
    </div>

    <div class="tags-row" role="group" aria-labelledby="topics-label">
      <span class="tags-row-label" id="topics-label">Topics</span>
      {topTags.map((t) => (
        <button
          type="button"
          class="chip chip-tag"
          data-tag={t}
          aria-pressed="false"
          aria-controls="artifact-catalog"
        >
          {t}
        </button>
      ))}
    </div>

    <div class="filter-status-row">
      <p class="result-status" id="result-status" role="status" aria-live="polite" aria-atomic="true">
        {artifacts.length} {artifacts.length === 1 ? 'artifact' : 'artifacts'} shown
      </p>
      <button class="clear-filters" id="clear-filters" type="button" hidden>Clear filters</button>
    </div>

    <div id="artifact-catalog">
      {orderedAreas.map((area) => (
        <section class="area-section">
          <h2 class="area-title">
            {area} <span class="area-count">{byArea.get(area)!.length}</span>
          </h2>
          <div class="grid">
            {byArea.get(area)!.map((artifact) => <ArtifactCard artifact={artifact} />)}
          </div>
        </section>
      ))}
    </div>

    <div class="empty" id="empty" hidden>No artifacts match your search.</div>
  </div>

  <script>
    const search = document.getElementById('search') as HTMLInputElement;
    const typeChips = document.querySelectorAll<HTMLButtonElement>('.chip-type');
    const tagChips = document.querySelectorAll<HTMLButtonElement>('.chip-tag');
    const cards = document.querySelectorAll<HTMLElement>('.card');
    const empty = document.getElementById('empty')!;
    const sections = document.querySelectorAll<HTMLElement>('.area-section');
    const resultStatus = document.getElementById('result-status')!;
    const clearFilters = document.getElementById('clear-filters') as HTMLButtonElement;
    const cardTags = new Map<HTMLElement, string[]>();
    cards.forEach((card) => {
      try {
        const parsed: unknown = JSON.parse(card.dataset.tags ?? '[]');
        cardTags.set(
          card,
          Array.isArray(parsed) ? parsed.filter((tag): tag is string => typeof tag === 'string') : []
        );
      } catch {
        cardTags.set(card, []);
      }
    });

    let activeType = 'all';
    let activeTag: string | null = null;

    function setActiveType(type: string) {
      activeType = type;
      typeChips.forEach((chip) => {
        const active = chip.dataset.filter === activeType;
        chip.classList.toggle('active', active);
        chip.setAttribute('aria-pressed', String(active));
      });
    }

    function setActiveTag(tag: string | null) {
      activeTag = tag;
      tagChips.forEach((chip) => {
        const active = chip.dataset.tag === activeTag;
        chip.classList.toggle('active', active);
        chip.setAttribute('aria-pressed', String(active));
      });
    }

    function apply() {
      const rawQuery = search.value.trim();
      const q = rawQuery.toLowerCase();
      let visible = 0;
      cards.forEach((card) => {
        const typeOk = activeType === 'all' || card.dataset.type === activeType;
        const textOk = !q || (card.dataset.search ?? '').includes(q);
        const tagOk = !activeTag || (cardTags.get(card) ?? []).includes(activeTag);
        const show = typeOk && textOk && tagOk;
        card.hidden = !show;
        if (show) visible++;
      });

      sections.forEach((section) => {
        const sectionCards = [...section.querySelectorAll<HTMLElement>('.card')];
        const sectionVisible = sectionCards.filter((card) => !card.hidden).length;
        section.hidden = sectionVisible === 0;
        const areaCount = section.querySelector<HTMLElement>('.area-count');
        if (areaCount) areaCount.textContent = String(sectionVisible);
      });

      empty.hidden = visible !== 0;
      const constraints: string[] = [];
      if (activeType !== 'all') {
        const chip = [...typeChips].find((item) => item.dataset.filter === activeType);
        constraints.push(chip?.dataset.label ?? activeType);
      }
      if (activeTag) constraints.push(`topic: ${activeTag}`);
      if (rawQuery) constraints.push(`search: “${rawQuery}”`);
      const suffix = constraints.length ? ` · ${constraints.join(' · ')}` : '';
      resultStatus.textContent = `${visible} ${visible === 1 ? 'artifact' : 'artifacts'} shown${suffix}`;
      clearFilters.hidden = constraints.length === 0;
    }

    search.addEventListener('input', apply);
    typeChips.forEach((chip) => {
      chip.addEventListener('click', () => {
        setActiveType(chip.dataset.filter ?? 'all');
        apply();
      });
    });

    tagChips.forEach((chip) => {
      chip.addEventListener('click', () => {
        const tag = chip.dataset.tag ?? null;
        setActiveTag(activeTag === tag ? null : tag);
        apply();
      });
    });

    clearFilters.addEventListener('click', () => {
      search.value = '';
      setActiveType('all');
      setActiveTag(null);
      apply();
      search.focus();
    });

    const topic = new URLSearchParams(window.location.search).get('topic');
    if (topic) {
      const chip = [...tagChips].find((c) => c.dataset.tag === topic);
      if (chip) {
        setActiveTag(topic);
      } else {
        search.value = topic;
        search.focus();
      }
    }
    apply();

    const fmt = new Intl.NumberFormat('en-US');
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    function showFinalCount(el: HTMLElement) {
      el.textContent = fmt.format(Number(el.dataset.target ?? '0'));
    }

    function countUp(el: HTMLElement) {
      const target = Number(el.dataset.target ?? '0');
      if (reduceMotion) {
        showFinalCount(el);
        return;
      }
      el.textContent = '0';
      const dur = 1100;
      const start = performance.now();
      function step(now: number) {
        const t = Math.min(1, (now - start) / dur);
        const eased = 1 - Math.pow(1 - t, 3);
        el.textContent = fmt.format(Math.round(target * eased));
        if (t < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
      setTimeout(() => (el.textContent = fmt.format(target)), dur + 400);
    }
    const heroNums = document.querySelectorAll<HTMLElement>('.stat-num');
    if (heroNums.length && !reduceMotion && 'IntersectionObserver' in window) {
      const heroStats = document.querySelector('.hero-stats')!;
      let counted = false;
      const io = new IntersectionObserver(
        (entries) => {
          if (entries[0].isIntersecting && !counted) {
            counted = true;
            heroNums.forEach(countUp);
            io.disconnect();
          }
        },
        { threshold: 0.5 }
      );
      io.observe(heroStats);
    } else {
      heroNums.forEach(showFinalCount);
    }
  </script>
</Base>
